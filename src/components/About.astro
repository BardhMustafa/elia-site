---
const principles = [
  {
    num: '01',
    title: 'Local expertise, global perspective',
    desc: 'We combine deep knowledge of Kosovo and the Balkans with an international network spanning Europe, the Gulf, and North America.',
  },
  {
    num: '02',
    title: 'Partnership-first mindset',
    desc: "We don't just advise — we work alongside you, shoulder to shoulder, until the goal is achieved.",
  },
  {
    num: '03',
    title: 'Speed without shortcuts',
    desc: 'We move fast because we know the terrain. Every step is deliberate, legally sound, and commercially sharp.',
  },
];
---

<section id="about" class="about">
  <div class="container">

    <!-- Header row -->
    <header class="about-head">
      <span class="eyebrow reveal">About Elia</span>
      <h2 class="about-title serif reveal reveal-1">
        A bridge between Kosovo<br />
        and the <span class="italic">rest of the world</span>.
      </h2>
    </header>

    <!-- Narrative grid -->
    <div class="about-grid">
      <div class="about-text reveal">
        <p class="about-lead">
          Elia Partnerships was founded on a simple observation: Kosovo and the Balkans are brimming with entrepreneurial talent and investment potential — yet the path to global markets, and into them, remains unnecessarily complex.
        </p>
        <p class="about-body">
          We exist to change that. Whether you're a Kosovar manufacturer ready to export, a franchise brand seeking a Southeast European foothold, or an international investor eyeing the region's growth story — Elia is your guide, navigator, and connector.
        </p>
        <p class="about-body">
          Our team combines legal, commercial, digital, and logistical expertise with an extensive local and international network. We're not generalists — every service we offer is something we've done repeatedly and well.
        </p>

        <a href="#contact" class="btn btn-dark about-cta">
          Work with us
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arr-right"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Aside: principles -->
      <aside class="about-principles reveal reveal-2">
        <span class="principles-label">Our principles</span>
        <ol class="principles-list">
          {principles.map((p) => (
            <li>
              <span class="p-num serif">{p.num}</span>
              <div class="p-body">
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </aside>
    </div>

  </div>
</section>

<style>
.about {
  background: var(--paper);
  padding: var(--section-pad) 0;
  color: var(--ink);
}

/* Head */
.about-head {
  display: grid;
  grid-template-columns: 1fr 3fr;
  gap: var(--s-4);
  align-items: start;
  padding-bottom: var(--s-5);
  margin-bottom: var(--s-5);
  border-bottom: 1px solid var(--line);
}
.about-title {
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--ink);
}
.about-title .italic { font-style: italic; color: var(--gold); }

/* Grid */
.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: var(--s-6);
  align-items: start;
}

/* Text */
.about-lead {
  font-family: var(--font-serif);
  font-size: clamp(1.25rem, 2vw, 1.5rem);
  line-height: 1.5;
  color: var(--ink);
  margin-bottom: var(--s-3);
  letter-spacing: -0.01em;
}
.about-body {
  font-size: var(--t-base);
  line-height: 1.75;
  color: var(--ink-60);
  margin-bottom: var(--s-3);
  max-width: 560px;
}
.about-cta { margin-top: var(--s-3); }

/* Principles aside */
.about-principles {
  border-top: 1px solid var(--line);
  padding-top: var(--s-3);
}
.principles-label {
  display: block;
  font-size: var(--t-xs);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-40);
  margin-bottom: var(--s-3);
}

.principles-list {
  display: flex;
  flex-direction: column;
  gap: var(--s-3);
  list-style: none;
}
.principles-list li {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: var(--s-2);
  padding-bottom: var(--s-3);
  border-bottom: 1px solid var(--line);
}
.principles-list li:last-child { border-bottom: none; padding-bottom: 0; }

.p-num {
  font-size: 1.25rem;
  font-weight: 500;
  color: var(--gold);
  line-height: 1;
  padding-top: 2px;
}
.p-body h3 {
  font-family: var(--font-serif);
  font-size: var(--t-lg);
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 0.35rem;
  letter-spacing: -0.01em;
  line-height: 1.3;
}
.p-body p {
  font-size: var(--t-sm);
  line-height: 1.65;
  color: var(--ink-60);
}

@media (max-width: 900px) {
  .about-head { grid-template-columns: 1fr; gap: var(--s-2); }
  .about-grid { grid-template-columns: 1fr; gap: var(--s-5); }
}
</style>
